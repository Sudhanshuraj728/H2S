# Server Configuration
PORT=8000
NODE_ENV=development

# Database (Atlas-first)
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/optiprimes?retryWrites=true&w=majority

# Optional: keep local URI for migration utility
LOCAL_MONGODB_URI=mongodb://localhost:27017/optiprimes

# Optional: explicit Atlas URI for migration utility
ATLAS_MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/optiprimes?retryWrites=true&w=majority

# CORS
CORS_ORIGIN=http://localhost:5173

# JWT Secrets
ACCESS_TOKEN_SECRET=your_access_token_secret_key_here_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here_min_32_chars

# JWT Expiry
ACCESS_TOKEN_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d
